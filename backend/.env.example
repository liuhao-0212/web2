# Set to 1 to use SQLite (backend/dev.sqlite) when MySQL is unavailable
# USE_SQLITE=1

# MySQL connection (copy to .env and adjust)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=webapp
MYSQL_PASSWORD=webapp_secret
MYSQL_DATABASE=webapp_db
FLASK_DEBUG=1
FLASK_PORT=5000
# SECRET_KEY=change-me-in-production
#
# Demo account (seeded if users table is empty): demo / demo123
